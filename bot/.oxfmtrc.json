{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "singleQuote": false,
  "semi": true,
  "useTabs": false,
  "tabWidth": 2,
  "bracketSpacing": true,
  "trailingComma": "all",
  "arrowParens": "always",
  "sortPackageJson": true,
  "ignorePatterns": ["node_modules", "dist", "*.lock", "*-lock.yaml"]
}
