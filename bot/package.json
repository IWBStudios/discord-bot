{
  "name": "discord-bot",
  "version": "0.1.2",
  "description": "A Discord Bot",
  "scripts": {
    "build": "pnpm run tsc",
    "start": "pnpm run dist/index.js",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "start:prod": "pnpm run build && pnpm run start:pm2",
    "dev": "nodemon -L",
    "format": "prettier --write src"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "discord.js": "^14.26.5",
    "dotenv": "^17.4.2",
    "pg": "^8.14.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  }
}
